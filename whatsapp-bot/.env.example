# ─── WhatsApp Bot Configuration ───────────────────────────────────────────────

# Port bot berjalan (harus sama dengan BOT_PORT di .env Laravel)
BOT_PORT=3000

# Secret key untuk autentikasi antara Laravel <-> Bot (harus sama di kedua sisi)
BOT_SECRET=rozitech-bot-secret-2024

# URL Laravel (tempat webhook dikirim)
APP_URL=http://127.0.0.1:8000

# ─── SESSION SECURITY ──────────────────────────────────────────────────────────
# ID session RESMI yang diizinkan menerima & mengirim pesan pelanggan.
# Hanya nomor WA yang di-pairing dengan ID ini yang dapat berinteraksi dengan pelanggan.
# Jika ada WA lain yang login (session berbeda), pesannya akan diabaikan otomatis.
# Default: main
MAIN_SESSION_ID=main
